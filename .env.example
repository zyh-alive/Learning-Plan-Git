# .env.example
# 复制此文件为 .env，并填入真实值

DB_PASSWORD=your_password_here
JWT_SECRET=your_secret_key_here
FEISHU_BOT_WEBHOOK=your_feishu_bot_webhook_here
REDIS_HOST=your_redis_host_here
REDIS_PORT=your_redis_port_here
# 早间播报：在 config.yaml 的 feishu.* 用 ${...} 引用；HOUR/MINUTE 可不设，播报模块默认 8:00
ENABLE_FEISHU_MORNING=1
FEISHU_MORNING_HOUR=your_morning_hour_here
FEISHU_MORNING_MINUTE=your_morning_minute_here

# 支付宝（config.yaml 里 alipay.* 用 ${...} 引用）
# 私钥/公钥必须整段放在一对双引号里，行与行之间用 \n（反斜杠+n）连接，不要换行写多行
# 示例：ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipaydev.com/gateway.do
# 必须公网 HTTPS，且与 cloudflared 当前域名一致；每次 quick tunnel 域名会变，需改 .env 并重启 node 后重新发起充值
# 示例：ALIPAY_NOTIFY_URL=https://loc-pads-asbestos-stored.trycloudflare.com/api/pay/notify/alipay
ALIPAY_NOTIFY_URL=https://你的公网域名/api/pay/notify/alipay