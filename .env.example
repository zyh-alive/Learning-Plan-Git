# .env.example
# 复制此文件为 .env，并填入真实值

DB_PASSWORD=your_password_here
JWT_SECRET=your_secret_key_here
FEISHU_BOT_WEBHOOK=your_feishu_bot_webhook_here
# 早间播报：在 config.yaml 的 feishu.* 用 ${...} 引用；HOUR/MINUTE 可不设，播报模块默认 8:00
ENABLE_FEISHU_MORNING=1
FEISHU_MORNING_HOUR=your_morning_hour_here
FEISHU_MORNING_MINUTE=your_morning_minute_here